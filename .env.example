# OpenAI-compatible Chat Completions endpoint. Must use HTTPS.
XL_AGENT_LLM_ENDPOINT=

# Model ID accepted by the configured endpoint.
XL_AGENT_LLM_MODEL=

# Secret read only by the Electron main process.
XL_AGENT_LLM_API_KEY=

# Optional approval lifetime in milliseconds. Defaults to 30 minutes.
XL_AGENT_APPROVAL_TTL_MS=1800000

# Optional absolute paths. When omitted, Electron uses its userData directory.
# XL_AGENT_TASK_STORE_PATH=/absolute/path/to/agent-tasks.sqlite
# XL_AGENT_WORKSPACE_ROOT=/absolute/path/to/workspaces
